# Playtomic API credentials
# Generate these in Playtomic Manager > Settings > Developer Tools
PLAYTOMIC_CLIENT_ID=your_client_id_here
PLAYTOMIC_SECRET=your_secret_here
PLAYTOMIC_TENANT_ID=your_venue_id_here

# PlaySight API credentials (request from PlaySight support)
PLAYSIGHT_API_URL=https://api.playsight.com
PLAYSIGHT_API_KEY=your_playsight_api_key_here
PLAYSIGHT_FACILITY_ID=your_facility_id_here

# Polling interval in minutes (default: 1)
POLL_INTERVAL_MINUTES=1

# How many minutes before match start to trigger recording (default: 2)
TRIGGER_AHEAD_MINUTES=2
